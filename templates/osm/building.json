{
  "$schema": "https://spatial-cms.dev/template/v1.json",
  "templateVersion": "1.0.0",
  "metadata": {
    "name": "OSM Building",
    "description": "Building model aligned with OpenStreetMap building tags. Suitable for importing and managing OSM building data.",
    "author": "Spatial CMS Community",
    "license": "ODbL-1.0",
    "tags": ["osm", "openstreetmap", "building", "footprint"]
  },
  "models": [
    {
      "key": "osm_building",
      "name": "OSM Building",
      "description": "Building footprint with OSM-compatible attributes",
      "geometryType": "POLYGON",
      "srid": 4326,
      "displayField": "name",
      "governance": {
        "approvalMode": "manual",
        "publishMode": "manual"
      },
      "fields": [
        {
          "key": "osm_id",
          "label": "OSM ID",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 0
        },
        {
          "key": "name",
          "label": "Name",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 1
        },
        {
          "key": "building_type",
          "label": "Building Type",
          "fieldType": "enum_",
          "enumValues": [
            "yes", "residential", "commercial", "industrial",
            "retail", "apartments", "house", "garage",
            "school", "church", "hospital", "office",
            "warehouse", "public", "other"
          ],
          "isRequired": false,
          "orderIndex": 2
        },
        {
          "key": "levels",
          "label": "Building Levels",
          "fieldType": "number",
          "isRequired": false,
          "validationJson": { "min": 0 },
          "orderIndex": 3
        },
        {
          "key": "height",
          "label": "Height (m)",
          "fieldType": "number",
          "isRequired": false,
          "validationJson": { "min": 0 },
          "orderIndex": 4
        },
        {
          "key": "addr_street",
          "label": "Street",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 5
        },
        {
          "key": "addr_housenumber",
          "label": "House Number",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 6
        },
        {
          "key": "addr_city",
          "label": "City",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 7
        },
        {
          "key": "addr_postcode",
          "label": "Postcode",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 8
        },
        {
          "key": "source",
          "label": "Source",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 9
        }
      ]
    }
  ],
  "dataset": {
    "name": "OSM Buildings",
    "description": "OpenStreetMap building footprint data",
    "license": "ODbL-1.0",
    "publishToDelivery": true,
    "publishToOgc": true
  }
}
