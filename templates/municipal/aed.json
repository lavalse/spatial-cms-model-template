{
  "$schema": "https://spatial-cms.dev/template/v1.json",
  "templateVersion": "1.0.0",
  "metadata": {
    "name": "自治体標準ODS - AED設置箇所一覧",
    "description": "Municipal Standard Open Data Set: AED installation locations. Single-model POINT template matching the official CSV column definition (Definition A) published by デジタル庁 (Japan Digital Agency). All field labels are the exact Japanese column names from the spec; field keys are English snake_case. Coordinates are WGS84 / EPSG:4326. Source: https://www.digital.go.jp/resources/open_data/municipal-standard-data-set-test",
    "author": "Spatial CMS Community",
    "license": "CC-BY-4.0",
    "tags": ["municipal", "japan", "ods", "aed", "emergency", "digital-agency"]
  },
  "models": [
    {
      "key": "municipal_aed",
      "name": "自治体標準ODS - AED設置箇所一覧",
      "description": "AED (Automated External Defibrillator) installation point inventory. Each row represents a single AED location with operating-hours metadata. Geometry is the installation point in WGS84.",
      "geometryType": "POINT",
      "srid": 4326,
      "displayField": "facility_name",
      "governance": {
        "approvalMode": "manual",
        "publishMode": "manual"
      },
      "fields": [
        {
          "key": "prefecture_code",
          "label": "都道府県コード",
          "fieldType": "string",
          "isRequired": true,
          "validationJson": { "pattern": "^[0-9]{2}$" },
          "orderIndex": 0
        },
        {
          "key": "municipality_code",
          "label": "市区町村コード",
          "fieldType": "string",
          "isRequired": true,
          "validationJson": { "pattern": "^[0-9]{3}$" },
          "orderIndex": 1
        },
        {
          "key": "prefecture",
          "label": "都道府県名",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 2
        },
        {
          "key": "municipality",
          "label": "市区町村名",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 3
        },
        {
          "key": "aed_id",
          "label": "AED_ID",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 4
        },
        {
          "key": "facility_name",
          "label": "施設名",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 5
        },
        {
          "key": "address",
          "label": "住所",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 6
        },
        {
          "key": "address_modifier",
          "label": "方書",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 7
        },
        {
          "key": "latitude",
          "label": "緯度",
          "fieldType": "number",
          "isRequired": true,
          "validationJson": { "minimum": 20, "maximum": 46 },
          "orderIndex": 8
        },
        {
          "key": "longitude",
          "label": "経度",
          "fieldType": "number",
          "isRequired": true,
          "validationJson": { "minimum": 122, "maximum": 154 },
          "orderIndex": 9
        },
        {
          "key": "phone_number",
          "label": "電話番号",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 10
        },
        {
          "key": "available_days",
          "label": "設置曜日",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 11
        },
        {
          "key": "start_time",
          "label": "開始時間",
          "fieldType": "string",
          "isRequired": false,
          "validationJson": { "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
          "orderIndex": 12
        },
        {
          "key": "end_time",
          "label": "終了時間",
          "fieldType": "string",
          "isRequired": false,
          "validationJson": { "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
          "orderIndex": 13
        },
        {
          "key": "url",
          "label": "URL",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 14
        },
        {
          "key": "remarks",
          "label": "備考",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 15
        }
      ]
    }
  ],
  "dataset": {
    "name": "AED設置箇所一覧",
    "description": "自治体標準オープンデータセット - AED設置箇所一覧 (デジタル庁仕様準拠)",
    "license": "CC-BY-4.0",
    "publishToDelivery": true,
    "publishToOgc": true
  }
}
