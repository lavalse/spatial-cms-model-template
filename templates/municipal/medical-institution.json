{
  "$schema": "https://spatial-cms.dev/template/v1.json",
  "templateVersion": "1.0.0",
  "metadata": {
    "name": "自治体標準ODS - 医療機関一覧",
    "description": "Municipal Standard Open Data Set: Medical institutions (病院/診療所/歯科/薬局 etc.). Single-model POINT template matching the official CSV column definition (Definition A) published by デジタル庁. Field labels are the exact Japanese column names from the spec; field keys are English snake_case. Coordinates are WGS84 / EPSG:4326. Source: https://www.digital.go.jp/resources/open_data/municipal-standard-data-set-test",
    "author": "Spatial CMS Community",
    "license": "CC-BY-4.0",
    "tags": ["municipal", "japan", "ods", "medical", "healthcare", "digital-agency"]
  },
  "models": [
    {
      "key": "municipal_medical_institution",
      "name": "自治体標準ODS - 医療機関一覧",
      "description": "Medical institution inventory. Each row represents one institution (hospital, clinic, dental clinic, pharmacy, etc.) with specialties, bed count, and contact metadata. Geometry is the representative point in WGS84.",
      "geometryType": "POINT",
      "srid": 4326,
      "displayField": "institution_name",
      "governance": {
        "approvalMode": "manual",
        "publishMode": "manual"
      },
      "fields": [
        {
          "key": "prefecture_code",
          "label": "都道府県コード",
          "fieldType": "string",
          "isRequired": true,
          "validationJson": { "pattern": "^[0-9]{2}$" },
          "orderIndex": 0
        },
        {
          "key": "municipality_code",
          "label": "市区町村コード",
          "fieldType": "string",
          "isRequired": true,
          "validationJson": { "pattern": "^[0-9]{3}$" },
          "orderIndex": 1
        },
        {
          "key": "prefecture",
          "label": "都道府県名",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 2
        },
        {
          "key": "municipality",
          "label": "市区町村名",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 3
        },
        {
          "key": "institution_id",
          "label": "医療機関ID",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 4
        },
        {
          "key": "institution_name",
          "label": "医療機関名",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 5
        },
        {
          "key": "institution_name_kana",
          "label": "医療機関名_カナ",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 6
        },
        {
          "key": "institution_category",
          "label": "医療機関区分",
          "fieldType": "enum_",
          "isRequired": false,
          "enumValues": [
            "病院",
            "診療所",
            "歯科診療所",
            "薬局",
            "助産所",
            "訪問看護ステーション",
            "その他"
          ],
          "orderIndex": 7
        },
        {
          "key": "address",
          "label": "住所",
          "fieldType": "string",
          "isRequired": true,
          "orderIndex": 8
        },
        {
          "key": "address_modifier",
          "label": "方書",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 9
        },
        {
          "key": "latitude",
          "label": "緯度",
          "fieldType": "number",
          "isRequired": true,
          "validationJson": { "minimum": 20, "maximum": 46 },
          "orderIndex": 10
        },
        {
          "key": "longitude",
          "label": "経度",
          "fieldType": "number",
          "isRequired": true,
          "validationJson": { "minimum": 122, "maximum": 154 },
          "orderIndex": 11
        },
        {
          "key": "phone_number",
          "label": "電話番号",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 12
        },
        {
          "key": "fax_number",
          "label": "FAX番号",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 13
        },
        {
          "key": "corporate_number",
          "label": "法人番号",
          "fieldType": "string",
          "isRequired": false,
          "validationJson": { "pattern": "^[0-9]{13}$" },
          "orderIndex": 14
        },
        {
          "key": "medical_specialties",
          "label": "診療科目",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 15
        },
        {
          "key": "bed_count",
          "label": "病床数",
          "fieldType": "number",
          "isRequired": false,
          "validationJson": { "minimum": 0 },
          "orderIndex": 16
        },
        {
          "key": "business_hours",
          "label": "営業時間",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 17
        },
        {
          "key": "url",
          "label": "URL",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 18
        },
        {
          "key": "remarks",
          "label": "備考",
          "fieldType": "string",
          "isRequired": false,
          "orderIndex": 19
        }
      ]
    }
  ],
  "dataset": {
    "name": "医療機関一覧",
    "description": "自治体標準オープンデータセット - 医療機関一覧 (デジタル庁仕様準拠)",
    "license": "CC-BY-4.0",
    "publishToDelivery": true,
    "publishToOgc": true
  }
}
